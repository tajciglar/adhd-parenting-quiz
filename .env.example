# Supabase Auth (required - used for JWT validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Database (set automatically by docker-compose, only needed for native dev)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adhd_assistant
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/adhd_assistant

# Gemini (required for AI chat)
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=text-embedding-004
