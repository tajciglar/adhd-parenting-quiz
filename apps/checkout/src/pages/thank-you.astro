---
import Base from '../layouts/Base.astro'

const childName = Astro.url.searchParams.get('childName') ?? 'your child'
const email     = Astro.url.searchParams.get('email') ?? ''
const gender    = Astro.url.searchParams.get('gender') ?? ''
const value     = Astro.url.searchParams.get('value') ?? '19'

const pronoun = gender === 'male' ? 'his' : gender === 'female' ? 'her' : 'their'
---

<Base title="Thank You! — ADHD Personality Report">
<script define:vars={{ purchaseValue: value, purchaseEmail: email }}>
  if (window.fbq) {
    window.fbq('track', 'Purchase', {
      value: parseFloat(purchaseValue) || 19,
      currency: 'USD',
      content_category: 'adhd_report',
    })
  }
</script>
  <div style="max-width:640px; margin:0 auto; padding:48px 20px 80px;">

    <!-- Success card -->
    <div class="card" style="text-align:center; margin-bottom:24px;">
      <div style="font-size:48px; margin-bottom:20px;">💜</div>

      <h1 style="font-size:var(--text-2xl); font-weight:var(--weight-bold); color:var(--color-primary); line-height:1.3; margin-bottom:20px;">
        Congratulations! You just invested in understanding {childName} more deeply.
      </h1>

      <p style="font-size:var(--text-base); color:var(--color-text-body); line-height:1.7; margin-bottom:16px;">
        What you just did – taking the time to truly see how <strong>{pronoun} brain works</strong> – is one of the most powerful things a parent can do.
      </p>

      <p style="font-size:var(--text-base); color:var(--color-text-body); line-height:1.7; margin-bottom:16px;">
        <strong>{childName}'s full ADHD Personality Report is on its way to your inbox right now.</strong>
        It should arrive in 2 minutes.
        {email && (
          <span> Check <span style="color:var(--color-primary); font-weight:var(--weight-medium);">{email}</span></span>
        )}
      </p>

      <p style="font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.6;">
        If you don't see it, check your spam folder and mark us as a contact:{' '}
        <a href="mailto:info@adhdparenting.com" style="color:var(--color-primary); text-decoration:underline;">
          info@adhdparenting.com
        </a>
      </p>
    </div>

    <!-- What happens next -->
    <div class="card">
      <h2 class="section-heading" style="font-size:var(--text-lg);">What happens next?</h2>
      <ol style="padding-left:20px; display:flex; flex-direction:column; gap:10px;">
        <li style="font-size:var(--text-base); color:var(--color-text-body); line-height:1.5;">
          Check your email — your report will arrive within 2 minutes.
        </li>
        <li style="font-size:var(--text-base); color:var(--color-text-body); line-height:1.5;">
          Open {childName}'s ADHD Personality Report and read {pronoun} full profile.
        </li>
        <li style="font-size:var(--text-base); color:var(--color-text-body); line-height:1.5;">
          Use the strategies section to start implementing changes today.
        </li>
      </ol>
    </div>

  </div>
</Base>
